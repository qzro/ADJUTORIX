{
  "adjutorix.agent.host": "http://127.0.0.1",
  "adjutorix.agent.port": 8765,
  "adjutorix.agent.autoStart": true,

  "adjutorix.ui.showDiffPreview": true,
  "adjutorix.ui.autoOpenPanel": true,
  "adjutorix.ui.confirmBeforeApply": true,

  "adjutorix.execution.defaultCheckCommand": "adjutorix check",
  "adjutorix.execution.defaultFixCommand": "adjutorix fix",
  "adjutorix.execution.defaultVerifyCommand": "adjutorix verify",
  "adjutorix.execution.defaultDeployCommand": "adjutorix deploy",

  "adjutorix.security.enableSecretsScan": true,
  "adjutorix.security.blockNetworkByDefault": true,
  "adjutorix.security.requireOverrideForProtectedFiles": true,

  "adjutorix.context.maxFiles": 12,
  "adjutorix.context.maxFileSizeKb": 256,
  "adjutorix.context.maxTokens": 8192,

  "adjutorix.models.fast": "qwen2.5-coder:7b",
  "adjutorix.models.strong": "deepseek-coder:33b",

  "adjutorix.logging.level": "info",
  "adjutorix.logging.persist": true,
  "adjutorix.logging.path": "~/.adjutorix/logs",

  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,

  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": true,
    "source.organizeImports": true
  },

  "terminal.integrated.scrollback": 5000,

  "git.autofetch": true,
  "git.confirmSync": false,

  "python.testing.pytestEnabled": true,
  "typescript.tsserver.experimental.enableProjectDiagnostics": true
}
