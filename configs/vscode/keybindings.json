    "args": "Agent: Check",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+alt+f",
    "command": "workbench.action.tasks.runTask",
    "args": "Agent: Fix",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+alt+v",
    "command": "workbench.action.tasks.runTask",
    "args": "Agent: Verify (CI Parity)",
