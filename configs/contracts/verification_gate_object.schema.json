{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adjutorix.local/contracts/verification_gate_object.schema.json",
  "title": "ADJUTORIX Verification Gate Object",
  "type": "object",
  "required": [
    "object_type",
    "schema_version",
    "verification_gate_id",
    "created_at",
    "plan_id",
    "patch_custody_id",
    "workspace_root",
    "custody",
    "basis",
    "inputs",
    "required_checks",
    "gate_state",
    "execution",
    "result",
    "apply_gate",
    "evidence"
  ],
  "properties": {
    "object_type": { "const": "ADJUTORIX_VERIFICATION_GATE_OBJECT" },
    "schema_version": { "const": "1.0.0" },
    "verification_gate_id": { "type": "string", "minLength": 12 },
    "created_at": { "type": "string", "minLength": 20 },
    "plan_id": { "type": "string", "minLength": 12 },
    "patch_custody_id": { "type": "string", "minLength": 12 },
    "workspace_root": { "type": "string", "minLength": 1 },
    "selected_path": { "type": ["string", "null"] },
    "custody": {
      "type": "object",
      "required": [
        "source",
        "workspace_bound",
        "plan_bound",
        "patch_custody_bound",
        "may_mutate_files",
        "may_apply_patch"
      ],
      "properties": {
        "source": { "const": "LOCAL_OPERATOR_COCKPIT" },
        "workspace_bound": { "const": true },
        "plan_bound": { "const": true },
        "patch_custody_bound": { "const": true },
        "may_mutate_files": { "const": false },
        "may_apply_patch": { "const": false }
      }
    },
    "basis": {
      "type": "object",
      "required": [
        "plan_object_type",
        "patch_custody_object_type",
        "plan_id",
        "patch_custody_id"
      ],
      "properties": {
        "plan_object_type": { "const": "ADJUTORIX_INTENT_PLAN_OBJECT" },
        "patch_custody_object_type": { "const": "ADJUTORIX_PATCH_CUSTODY_OBJECT" },
        "plan_id": { "type": "string", "minLength": 12 },
        "patch_custody_id": { "type": "string", "minLength": 12 }
      }
    },
    "inputs": {
      "type": "object",
      "required": [
        "runtime_ready",
        "diagnostics_ready",
        "plan_valid",
        "patch_custody_valid"
      ],
      "properties": {
        "runtime_ready": { "type": "boolean" },
        "diagnostics_ready": { "type": "boolean" },
        "plan_valid": { "const": true },
        "patch_custody_valid": { "const": true }
      }
    },
    "required_checks": {
      "type": "array",
      "minItems": 3,
      "items": { "type": "string" }
    },
    "gate_state": {
      "type": "object",
      "required": [
        "state",
        "verify_executed",
        "apply_unlocked"
      ],
      "properties": {
        "state": {
          "enum": [
            "GATE_CREATED_NOT_EXECUTED",
            "VERIFY_INPUTS_INCOMPLETE",
            "VERIFY_READY_TO_RUN"
          ]
        },
        "verify_executed": { "const": false },
        "apply_unlocked": { "const": false }
      }
    },
    "execution": {
      "type": "object",
      "required": [
        "mode",
        "executed",
        "receipt_required"
      ],
      "properties": {
        "mode": { "const": "OPERATOR_TRIGGERED" },
        "executed": { "const": false },
        "receipt_required": { "const": true }
      }
    },
    "result": {
      "type": "object",
      "required": [
        "verdict",
        "verify_receipt_required"
      ],
      "properties": {
        "verdict": { "const": "PENDING" },
        "verify_receipt_required": { "const": true }
      }
    },
    "apply_gate": {
      "type": "object",
      "required": [
        "blocked",
        "blocked_until_verify_pass",
        "requires_apply_receipt"
      ],
      "properties": {
        "blocked": { "const": true },
        "blocked_until_verify_pass": { "const": true },
        "requires_apply_receipt": { "const": true }
      }
    },
    "evidence": {
      "type": "object",
      "required": [
        "receipt_type",
        "timeline_event"
      ],
      "properties": {
        "receipt_type": { "const": "verification_gate_receipt" },
        "timeline_event": { "const": "verification.gate.created" }
      }
    }
  }
}
