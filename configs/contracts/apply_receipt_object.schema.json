{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adjutorix.local/contracts/apply_receipt_object.schema.json",
  "title": "ADJUTORIX Apply Receipt Object",
  "type": "object",
  "required": [
    "object_type",
    "schema_version",
    "apply_receipt_id",
    "created_at",
    "plan_id",
    "patch_custody_id",
    "verification_gate_id",
    "verify_receipt_id",
    "apply_gate_id",
    "workspace_root",
    "custody",
    "basis",
    "execution",
    "result",
    "rollback_gate",
    "evidence"
  ],
  "properties": {
    "object_type": { "const": "ADJUTORIX_APPLY_RECEIPT_OBJECT" },
    "schema_version": { "const": "1.0.0" },
    "apply_receipt_id": { "type": "string", "minLength": 12 },
    "created_at": { "type": "string", "minLength": 20 },
    "plan_id": { "type": "string", "minLength": 12 },
    "patch_custody_id": { "type": "string", "minLength": 12 },
    "verification_gate_id": { "type": "string", "minLength": 12 },
    "verify_receipt_id": { "type": "string", "minLength": 12 },
    "apply_gate_id": { "type": "string", "minLength": 12 },
    "workspace_root": { "type": "string", "minLength": 1 },
    "selected_path": { "type": ["string", "null"] },
    "custody": {
      "type": "object",
      "required": [
        "source",
        "workspace_bound",
        "plan_bound",
        "patch_custody_bound",
        "verification_gate_bound",
        "verify_receipt_bound",
        "apply_gate_bound",
        "may_mutate_files",
        "may_apply_patch"
      ],
      "properties": {
        "source": { "const": "LOCAL_OPERATOR_COCKPIT" },
        "workspace_bound": { "const": true },
        "plan_bound": { "const": true },
        "patch_custody_bound": { "const": true },
        "verification_gate_bound": { "const": true },
        "verify_receipt_bound": { "const": true },
        "apply_gate_bound": { "const": true },
        "may_mutate_files": { "const": false },
        "may_apply_patch": { "const": false }
      }
    },
    "basis": {
      "type": "object",
      "required": [
        "plan_object_type",
        "patch_custody_object_type",
        "verification_gate_object_type",
        "verify_receipt_object_type",
        "apply_gate_object_type",
        "plan_id",
        "patch_custody_id",
        "verification_gate_id",
        "verify_receipt_id",
        "apply_gate_id"
      ],
      "properties": {
        "plan_object_type": { "const": "ADJUTORIX_INTENT_PLAN_OBJECT" },
        "patch_custody_object_type": { "const": "ADJUTORIX_PATCH_CUSTODY_OBJECT" },
        "verification_gate_object_type": { "const": "ADJUTORIX_VERIFICATION_GATE_OBJECT" },
        "verify_receipt_object_type": { "const": "ADJUTORIX_VERIFY_RECEIPT_OBJECT" },
        "apply_gate_object_type": { "const": "ADJUTORIX_APPLY_GATE_OBJECT" },
        "plan_id": { "type": "string", "minLength": 12 },
        "patch_custody_id": { "type": "string", "minLength": 12 },
        "verification_gate_id": { "type": "string", "minLength": 12 },
        "verify_receipt_id": { "type": "string", "minLength": 12 },
        "apply_gate_id": { "type": "string", "minLength": 12 }
      }
    },
    "execution": {
      "type": "object",
      "required": [
        "mode",
        "executed",
        "operator_triggered",
        "files_mutated"
      ],
      "properties": {
        "mode": { "const": "OPERATOR_TRIGGERED" },
        "executed": { "const": true },
        "operator_triggered": { "const": true },
        "files_mutated": { "const": false }
      }
    },
    "result": {
      "type": "object",
      "required": [
        "status",
        "applied",
        "reason"
      ],
      "properties": {
        "status": { "const": "APPLY_RECEIPT_CREATED" },
        "applied": { "const": true },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "rollback_gate": {
      "type": "object",
      "required": [
        "rollback_available",
        "requires_rollback_receipt",
        "basis_apply_receipt_id"
      ],
      "properties": {
        "rollback_available": { "const": true },
        "requires_rollback_receipt": { "const": true },
        "basis_apply_receipt_id": { "type": "string", "minLength": 12 }
      }
    },
    "evidence": {
      "type": "object",
      "required": [
        "receipt_type",
        "timeline_event"
      ],
      "properties": {
        "receipt_type": { "const": "apply_receipt" },
        "timeline_event": { "const": "apply.receipt.created" }
      }
    }
  }
}
