{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adjutorix.local/contracts/verify_receipt_object.schema.json",
  "title": "ADJUTORIX Verify Receipt Object",
  "type": "object",
  "required": [
    "object_type",
    "schema_version",
    "verify_receipt_id",
    "created_at",
    "plan_id",
    "patch_custody_id",
    "verification_gate_id",
    "workspace_root",
    "custody",
    "basis",
    "execution",
    "checks",
    "verdict",
    "apply_gate",
    "rollback_gate",
    "evidence"
  ],
  "properties": {
    "object_type": { "const": "ADJUTORIX_VERIFY_RECEIPT_OBJECT" },
    "schema_version": { "const": "1.0.0" },
    "verify_receipt_id": { "type": "string", "minLength": 12 },
    "created_at": { "type": "string", "minLength": 20 },
    "plan_id": { "type": "string", "minLength": 12 },
    "patch_custody_id": { "type": "string", "minLength": 12 },
    "verification_gate_id": { "type": "string", "minLength": 12 },
    "workspace_root": { "type": "string", "minLength": 1 },
    "selected_path": { "type": ["string", "null"] },
    "custody": {
      "type": "object",
      "required": [
        "source",
        "workspace_bound",
        "plan_bound",
        "patch_custody_bound",
        "verification_gate_bound",
        "may_mutate_files",
        "may_apply_patch"
      ],
      "properties": {
        "source": { "const": "LOCAL_OPERATOR_COCKPIT" },
        "workspace_bound": { "const": true },
        "plan_bound": { "const": true },
        "patch_custody_bound": { "const": true },
        "verification_gate_bound": { "const": true },
        "may_mutate_files": { "const": false },
        "may_apply_patch": { "const": false }
      }
    },
    "basis": {
      "type": "object",
      "required": [
        "plan_object_type",
        "patch_custody_object_type",
        "verification_gate_object_type",
        "plan_id",
        "patch_custody_id",
        "verification_gate_id"
      ],
      "properties": {
        "plan_object_type": { "const": "ADJUTORIX_INTENT_PLAN_OBJECT" },
        "patch_custody_object_type": { "const": "ADJUTORIX_PATCH_CUSTODY_OBJECT" },
        "verification_gate_object_type": { "const": "ADJUTORIX_VERIFICATION_GATE_OBJECT" },
        "plan_id": { "type": "string", "minLength": 12 },
        "patch_custody_id": { "type": "string", "minLength": 12 },
        "verification_gate_id": { "type": "string", "minLength": 12 }
      }
    },
    "execution": {
      "type": "object",
      "required": [
        "mode",
        "executed",
        "runtime_ready",
        "diagnostics_ready"
      ],
      "properties": {
        "mode": { "const": "OPERATOR_TRIGGERED" },
        "executed": { "const": true },
        "runtime_ready": { "type": "boolean" },
        "diagnostics_ready": { "type": "boolean" }
      }
    },
    "checks": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["command", "status"],
        "properties": {
          "command": { "type": "string", "minLength": 1 },
          "status": { "enum": ["PASS", "BLOCKED"] }
        }
      }
    },
    "verdict": {
      "type": "object",
      "required": [
        "status",
        "passed",
        "reason"
      ],
      "properties": {
        "status": { "enum": ["PASS", "BLOCKED"] },
        "passed": { "type": "boolean" },
        "reason": { "type": "string" }
      }
    },
    "apply_gate": {
      "type": "object",
      "required": [
        "unlocked",
        "requires_apply_receipt"
      ],
      "properties": {
        "unlocked": { "type": "boolean" },
        "requires_apply_receipt": { "const": true }
      }
    },
    "rollback_gate": {
      "type": "object",
      "required": [
        "required_after_apply",
        "requires_rollback_receipt"
      ],
      "properties": {
        "required_after_apply": { "const": true },
        "requires_rollback_receipt": { "const": true }
      }
    },
    "evidence": {
      "type": "object",
      "required": [
        "receipt_type",
        "timeline_event"
      ],
      "properties": {
        "receipt_type": { "const": "verify_receipt" },
        "timeline_event": { "const": "verify.receipt.created" }
      }
    }
  }
}
