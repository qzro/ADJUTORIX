#!/usr/bin/env bash

# Adjutorix Commit Message Policy Hook
# Enforces structured, auditable commit messages

set -e

COMMIT_MSG_FILE="$1"
MSG="$(cat "$COMMIT_MSG_FILE")"

# Allowed types
TYPES="feat|fix|refactor|test|docs|chore|build|ci|security|perf|revert"

# Max length
MAX_LENGTH=72

# Check empty
if [[ -z "$MSG" ]]; then
  echo "❌ Commit message is empty."
  exit 1
fi

# Check format: type(scope?): message
if ! echo "$MSG" | grep -Eq "^($TYPES)(\([a-zA-Z0-9_-]+\))?: .+"; then
  echo "❌ Invalid commit format."
  echo "Expected: type(scope?): short description"
  echo "Example: fix(agent): handle rpc timeout"
  exit 1
fi

# Check first line length
FIRST_LINE="$(echo "$MSG" | head -n1)"

if [[ ${#FIRST_LINE} -gt $MAX_LENGTH ]]; then
  echo "❌ Commit message too long (${#FIRST_LINE} > $MAX_LENGTH chars)."
  exit 1
fi

# Block WIP
if echo "$MSG" | grep -qi "wip"; then
  echo "❌ WIP commits are not allowed."
  exit 1
fi

# Enforce reference to job ledger when available
if [[ -d ".agent/jobs" ]]; then
  if ! echo "$MSG" | grep -Eq "JOB:[0-9]{8}_[0-9]{4}"; then
    echo "⚠️  Warning: No JOB reference found (JOB:YYYYMMDD_HHMM)."
  fi
fi

exit 0
