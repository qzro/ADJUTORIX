{
  "schema_version": "1.0.0",
  "policy_type": "ADJUTORIX_VERIFICATION_GATE_POLICY",
  "verification_gate_object_type": "ADJUTORIX_VERIFICATION_GATE_OBJECT",
  "source": "LOCAL_OPERATOR_COCKPIT",
  "requires_plan_object": true,
  "requires_patch_custody_object": true,
  "requires_workspace_bound": true,
  "verification_gate_may_not_mutate_files": true,
  "verification_gate_may_not_apply_patch": true,
  "verify_execution_requires_operator_trigger": true,
  "verify_execution_requires_runtime": true,
  "verify_execution_requires_diagnostics": true,
  "verify_receipt_required": true,
  "apply_locked_until_verify_pass": true,
  "apply_requires_apply_receipt": true,
  "rollback_requires_apply_receipt": true,
  "required_checks": [
    "pnpm verify",
    "node scripts/product/assert-local-operator-cockpit.mjs",
    "node scripts/product/assert-intent-plan-object.mjs",
    "node scripts/product/assert-patch-custody-object.mjs",
    "node scripts/product/assert-verification-gate-object.mjs"
  ],
  "receipt_sequence": [
    "intent_receipt",
    "plan_receipt",
    "patch_custody_receipt",
    "verification_gate_receipt",
    "verify_receipt",
    "apply_receipt",
    "rollback_receipt"
  ]
}
