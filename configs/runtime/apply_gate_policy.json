{
  "schema_version": "1.0.0",
  "policy_type": "ADJUTORIX_APPLY_GATE_POLICY",
  "apply_gate_object_type": "ADJUTORIX_APPLY_GATE_OBJECT",
  "source": "LOCAL_OPERATOR_COCKPIT",
  "requires_plan_object": true,
  "requires_patch_custody_object": true,
  "requires_verification_gate_object": true,
  "requires_verify_receipt_object": true,
  "requires_verify_receipt_pass": true,
  "requires_workspace_bound": true,
  "apply_gate_may_not_mutate_files": true,
  "apply_gate_may_not_apply_patch": true,
  "apply_gate_unlocks_apply_only_on_verify_receipt_pass": true,
  "apply_execution_requires_operator_trigger": true,
  "apply_execution_requires_apply_receipt": true,
  "rollback_required_after_apply": true,
  "rollback_requires_apply_receipt": true,
  "required_checks": [
    "pnpm verify",
    "node scripts/product/assert-local-operator-cockpit.mjs",
    "node scripts/product/assert-intent-plan-object.mjs",
    "node scripts/product/assert-patch-custody-object.mjs",
    "node scripts/product/assert-verification-gate-object.mjs",
    "node scripts/product/assert-verify-receipt-object.mjs",
    "node scripts/product/assert-apply-gate-object.mjs"
  ],
  "receipt_sequence": [
    "intent_receipt",
    "plan_receipt",
    "patch_custody_receipt",
    "verification_gate_receipt",
    "verify_receipt",
    "apply_gate_receipt",
    "apply_receipt",
    "rollback_receipt"
  ]
}
