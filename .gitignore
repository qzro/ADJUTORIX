# Node / JS
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
**/.npmrc

# Builds
**/dist/
**/build/
**/.turbo/
**/.parcel-cache/
**/.vite/
**/coverage/

# Python
**/.venv/
**/__pycache__/
**/*.pyc
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp

# Adjutorix runtime (generated) — ignore everything, keep sentinel files
runtime/*
!runtime/.keep
runtime/sessions/*
!runtime/sessions/.keep
runtime/sessions/ui/*
!runtime/sessions/ui/.keep
runtime/sessions/agent/*
!runtime/sessions/agent/.keep

# Never allow package-local runtimes (generated)
packages/**/runtime/

# === Recursive ignores for monorepo ===
**/*.vsix
**/*.egg-info/
**/.agent/

# deps
node_modules/

# Never allow package-local runtimes (generated)
packages/**/runtime/
