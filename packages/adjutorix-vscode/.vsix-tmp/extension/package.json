{
  "name": "adjutorix-vscode",
  "private": true,
  "displayName": "ADJUTORIX",
  "files": [
    "dist/**",
    "media/**",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "description": "Zero-cost local AI coding agent with governance, diff control, and offline execution.",
  "version": "0.1.1",
  "publisher": "adjutorix",
  "license": "MIT",
  "engines": {
    "vscode": ">=1.75.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Debuggers"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:adjutorix.panel",
    "onCommand:adjutorix.smoke",
    "onCommand:adjutorix.showSidebar",
    "onCommand:adjutorix.open",
    "onCommand:adjutorix.check",
    "onCommand:adjutorix.fix",
    "onCommand:adjutorix.verify",
    "onCommand:adjutorix.deploy"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      { "command": "adjutorix.smoke", "title": "Adjutorix: Smoke Test", "category": "Adjutorix" },
      { "command": "adjutorix.showSidebar", "title": "Adjutorix: Show Sidebar", "category": "Adjutorix" },
      { "command": "adjutorix.open", "title": "Adjutorix: Open", "category": "Adjutorix" },
      { "command": "adjutorix.check", "title": "Adjutorix: Check", "category": "Adjutorix" },
      { "command": "adjutorix.fix", "title": "Adjutorix: Fix", "category": "Adjutorix" },
      { "command": "adjutorix.verify", "title": "Adjutorix: Verify", "category": "Adjutorix" },
      { "command": "adjutorix.deploy", "title": "Adjutorix: Deploy", "category": "Adjutorix" }
    ],
    "menus": {
      "commandPalette": [
        { "command": "adjutorix.smoke" },
        { "command": "adjutorix.showSidebar" },
        { "command": "adjutorix.open" },
        { "command": "adjutorix.check" },
        { "command": "adjutorix.fix" },
        { "command": "adjutorix.verify" },
        { "command": "adjutorix.deploy" }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "ADJUTORIX",
      "properties": {
        "adjutorix.agentHost": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Local agent host"
        },
        "adjutorix.agentPort": {
          "type": "number",
          "default": 7337,
          "description": "Local agent port"
        },
        "adjutorix.autoStartAgent": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start local agent"
        },
        "adjutorix.logLevel": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "default": "info",
          "description": "Extension log level"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "adjutorix",
          "title": "ADJUTORIX",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "adjutorix": [
        {
          "id": "adjutorix.panel",
          "name": "Adjutorix"
        }
      ]
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && webpack --mode production",
    "watch": "webpack --watch --mode development",
    "lint": "eslint src --ext ts",
    "test": "vitest",
    "vsix": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "node-fetch": "^2.7.0",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "rimraf": "^5.0.5",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "@vscode/vsce": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/midiakiasat/ADJUTORIX"
  },
  "bugs": {
    "url": "https://github.com/midiakiasat/ADJUTORIX/issues"
  },
  "homepage": "https://github.com/midiakiasat/ADJUTORIX#readme"
}
