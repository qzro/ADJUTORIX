{
  "name": "adjutorix-vscode",
  "private": true,
  "displayName": "ADJUTORIX",
  "files": [
    "dist/**",
    "media/**",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "description": "Zero-cost local AI coding agent with governance, diff control, and offline execution.",
  "version": "1.0.0-unified",
  "publisher": "adjutorix",
  "license": "MIT",
  "engines": {
    "vscode": ">=1.75.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Debuggers"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:adjutorix.surface",
    "onCommand:adjutorix.smoke",
    "onCommand:adjutorix.whereAmI",
    "onCommand:adjutorix.showSidebar",
    "onCommand:adjutorix.open",
    "onCommand:adjutorix.startAgent",
    "onCommand:adjutorix.stopAgent",
    "onCommand:adjutorix.restartAgent",
    "onCommand:adjutorix.diagnostics",
    "onCommand:adjutorix.copyDiagnostics",
    "onCommand:adjutorix.setAgentModeAuto",
    "onCommand:adjutorix.setAgentModeManaged",
    "onCommand:adjutorix.setAgentModeExternal",
    "onCommand:adjutorix.check",
    "onCommand:adjutorix.fix",
    "onCommand:adjutorix.verify",
    "onCommand:adjutorix.deploy"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "adjutorix.smoke",
        "title": "Adjutorix: Smoke Test",
        "category": "Adjutorix"
      },
      {
        "command": "adjutorix.whereAmI",
        "title": "Adjutorix: Where Am I?",
        "category": "Adjutorix"
      },
      {
        "command": "adjutorix.showSidebar",
        "title": "Adjutorix: Show Sidebar",
        "category": "Adjutorix"
      },
      {
        "command": "adjutorix.open",
        "title": "Adjutorix: Open",
        "category": "Adjutorix"
      },
      {
        "command": "adjutorix.startAgent",
        "title": "Adjutorix: Start Agent",
        "category": "Adjutorix"
      },
      {
        "command": "adjutorix.stopAgent",
        "title": "Adjutorix: Stop Agent",
        "category": "Adjutorix"
      },
      {
        "command": "adjutorix.restartAgent",
        "title": "Adjutorix: Restart Agent",
        "category": "Adjutorix"
      },
      {
        "command": "adjutorix.diagnostics",
        "title": "Adjutorix: Diagnostics",
        "category": "Adjutorix"
      },
      {
        "command": "adjutorix.copyDiagnostics",
        "title": "Adjutorix: Copy Diagnostics",
        "category": "Adjutorix"
      },
      {
        "command": "adjutorix.setAgentModeAuto",
        "title": "Adjutorix: Set Agent Mode — Auto",
        "category": "Adjutorix"
      },
      {
        "command": "adjutorix.setAgentModeManaged",
        "title": "Adjutorix: Set Agent Mode — Managed",
        "category": "Adjutorix"
      },
      {
        "command": "adjutorix.setAgentModeExternal",
        "title": "Adjutorix: Set Agent Mode — External",
        "category": "Adjutorix"
      },
      {
        "command": "adjutorix.check",
        "title": "Adjutorix: Check",
        "category": "Adjutorix"
      },
      {
        "command": "adjutorix.fix",
        "title": "Adjutorix: Fix",
        "category": "Adjutorix"
      },
      {
        "command": "adjutorix.verify",
        "title": "Adjutorix: Verify",
        "category": "Adjutorix"
      },
      {
        "command": "adjutorix.deploy",
        "title": "Adjutorix: Deploy",
        "category": "Adjutorix"
      },
      {
        "command": "adjutorix.openWorkspaceFolder",
        "title": "Adjutorix: Open Workspace Folder",
        "category": "Adjutorix"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "adjutorix.smoke"
        },
        {
          "command": "adjutorix.whereAmI"
        },
        {
          "command": "adjutorix.showSidebar"
        },
        {
          "command": "adjutorix.open"
        },
        {
          "command": "adjutorix.startAgent"
        },
        {
          "command": "adjutorix.stopAgent"
        },
        {
          "command": "adjutorix.restartAgent"
        },
        {
          "command": "adjutorix.diagnostics"
        },
        {
          "command": "adjutorix.copyDiagnostics"
        },
        {
          "command": "adjutorix.setAgentModeAuto"
        },
        {
          "command": "adjutorix.setAgentModeManaged"
        },
        {
          "command": "adjutorix.setAgentModeExternal"
        },
        {
          "command": "adjutorix.check"
        },
        {
          "command": "adjutorix.fix"
        },
        {
          "command": "adjutorix.verify"
        },
        {
          "command": "adjutorix.deploy"
        },
        {
          "command": "adjutorix.openWorkspaceFolder"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "ADJUTORIX",
      "properties": {
        "adjutorix.agentHost": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Local agent host"
        },
        "adjutorix.agentPort": {
          "type": "number",
          "default": 7337,
          "description": "Local agent port"
        },
        "adjutorix.agentUrl": {
          "type": "string",
          "description": "Override agent base URL (e.g. http://127.0.0.1:7338). If set, agentHost/agentPort are ignored."
        },
        "adjutorix.agentMode": {
          "type": "string",
          "enum": [
            "auto",
            "managed",
            "external"
          ],
          "default": "auto",
          "description": "Agent control: auto (try managed, allow external), managed (spawn/kill only), external (health-check only)."
        },
        "adjutorix.autoStartAgent": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start local agent"
        },
        "adjutorix.logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "default": "info",
          "description": "Extension log level"
        },
        "adjutorix.workspacePath": {
          "type": "string",
          "description": "When no folder is open, open this path so the agent can start (e.g. your ADJUTORIX repo)."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "adjutorix",
          "title": "ADJUTORIX",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "adjutorix": [
        {
          "id": "adjutorix.surface",
          "name": "Adjutorix",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && webpack --mode production",
    "watch": "webpack --watch --mode development",
    "lint": "ESLINT_USE_FLAT_CONFIG=true eslint src",
    "test": "vitest",
    "vsix": "node scripts/patch-secretlint-concurrency.js && vsce package --no-dependencies",
    "vsix:install-vscode": "npm run vsix && \"/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code\" --install-extension \"$(pwd)/adjutorix-vscode-1.0.0-unified.vsix\" --force",
    "publish": "vsce publish",
    "postinstall": "node scripts/patch-secretlint-concurrency.js 2>/dev/null || true"
  },
  "dependencies": {
    "node-fetch": "^2.7.0",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/vsce": "^2.26.1",
    "eslint": "^8.56.0",
    "rimraf": "^5.0.5",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/midiakiasat/ADJUTORIX"
  },
  "bugs": {
    "url": "https://github.com/midiakiasat/ADJUTORIX/issues"
  },
  "homepage": "https://github.com/midiakiasat/ADJUTORIX/adjutorix#readme"
}
