{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adjutorix.local/schemas/toolcall.schema.json",
  "title": "AdjutorixToolCall",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "tool",
    "arguments",
    "timeout_sec"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "description": "Unique tool call identifier"
    },
    "tool": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Registered tool name"
    },
    "arguments": {
      "type": "object",
      "description": "Tool-specific arguments",
      "additionalProperties": true
    },
    "timeout_sec": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3600,
      "description": "Maximum execution time in seconds"
    },
    "working_directory": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096
    },
    "env": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "description": "Environment variables override"
    },
    "allow_network": {
      "type": "boolean",
      "default": false
    },
    "requires_confirmation": {
      "type": "boolean",
      "default": false
    },
    "on_failure": {
      "type": "string",
      "enum": ["abort", "continue", "rollback"],
      "default": "abort"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional tracing metadata"
    }
  }
}
