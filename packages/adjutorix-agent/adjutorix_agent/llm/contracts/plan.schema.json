{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adjutorix.local/schemas/plan.schema.json",
  "title": "AdjutorixPlan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "objective",
    "workspace",
    "files_to_touch",
    "commands_to_run",
    "pass_condition",
    "rollback_plan"
  ],
  "properties": {
    "objective": {
      "type": "string",
      "minLength": 3,
      "maxLength": 4000
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "root_path"],
      "properties": {
        "repo": { "type": "string", "minLength": 1, "maxLength": 200 },
        "root_path": { "type": "string", "minLength": 1, "maxLength": 4096 }
      }
    },
    "files_to_touch": {
      "type": "array",
      "minItems": 0,
      "maxItems": 200,
      "items": { "type": "string", "minLength": 1, "maxLength": 4096 }
    },
    "commands_to_run": {
      "type": "array",
      "minItems": 0,
      "maxItems": 50,
      "items": { "type": "string", "minLength": 1, "maxLength": 4000 }
    },
    "pass_condition": {
      "type": "string",
      "minLength": 3,
      "maxLength": 2000
    },
    "rollback_plan": {
      "type": "string",
      "minLength": 3,
      "maxLength": 4000
    },
    "assumptions": {
      "type": "array",
      "minItems": 0,
      "maxItems": 100,
      "items": { "type": "string", "minLength": 1, "maxLength": 2000 }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_files_touched": { "type": "integer", "minimum": 1, "maximum": 500 },
        "allow_network": { "type": "boolean" },
        "requires_approval": { "type": "boolean" }
      }
    }
  }
}
