{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adjutorix.local/schemas/patch.schema.json",
  "title": "AdjutorixPatch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "objective",
    "files",
    "diff",
    "expected_effect",
    "atomic",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "description": "Unique patch identifier"
    },
    "objective": {
      "type": "string",
      "minLength": 3,
      "maxLength": 2048,
      "description": "Reason and goal of this patch"
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 4096
      },
      "description": "Files touched by this patch"
    },
    "diff": {
      "type": "string",
      "minLength": 10,
      "description": "Unified diff content"
    },
    "expected_effect": {
      "type": "string",
      "minLength": 3,
      "maxLength": 4096,
      "description": "Expected behavioral or structural change"
    },
    "atomic": {
      "type": "boolean",
      "description": "Whether this patch must succeed fully or rollback"
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"],
      "default": "low"
    },
    "requires_override": {
      "type": "boolean",
      "default": false,
      "description": "True if protected files are modified"
    },
    "rollback_strategy": {
      "type": "string",
      "enum": ["git", "reverse_patch", "manual"],
      "default": "git"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 creation timestamp"
    },
    "author": {
      "type": "string",
      "maxLength": 256,
      "default": "adjutorix-agent"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional tracing metadata"
    }
  }
}
