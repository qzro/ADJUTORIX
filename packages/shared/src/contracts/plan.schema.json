{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Adjutorix Plan Schema",
  "type": "object",
  "required": [
    "objective",
    "files",
    "commands",
    "pass_condition",
    "rollback_plan"
  ],
  "properties": {
    "objective": {
      "type": "string",
      "minLength": 10,
      "description": "High-level description of what this job intends to accomplish."
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "description": "List of files expected to be modified."
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "description": "Commands that must be executed during VERIFY."
    },
    "pass_condition": {
      "type": "string",
      "minLength": 5,
      "description": "Definition of what constitutes success."
    },
    "rollback_plan": {
      "type": "string",
      "minLength": 5,
      "description": "Steps to restore previous state if verification fails."
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "default": "medium"
    },
    "requires_override": {
      "type": "boolean",
      "default": false
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
