{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Adjutorix Patch Schema",
  "type": "object",
  "required": [
    "id",
    "description",
    "files",
    "diff",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 8,
      "description": "Unique patch identifier."
    },
    "description": {
      "type": "string",
      "minLength": 5,
      "description": "Human-readable reason for this patch."
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "description": "List of files touched by this patch.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "diff": {
      "type": "string",
      "minLength": 10,
      "description": "Unified diff content."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp of patch creation."
    },
    "author": {
      "type": "string",
      "description": "Agent or user that generated the patch."
    },
    "expected_effect": {
      "type": "string",
      "description": "Expected behavioral change after applying patch."
    },
    "requires_override": {
      "type": "boolean",
      "default": false,
      "description": "Whether this patch requires explicit override approval."
    },
    "rollback_diff": {
      "type": "string",
      "description": "Optional reverse diff for deterministic rollback."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Agent confidence score for this patch."
    }
  },
  "additionalProperties": false
}
