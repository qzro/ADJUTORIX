{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Adjutorix Policy Schema",
  "type": "object",
  "required": [
    "version",
    "allowed_commands",
    "denied_commands",
    "protected_files",
    "limits"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Policy schema version (semver)."
    },
    "allowed_commands": {
      "type": "array",
      "minItems": 1,
      "description": "Explicitly allowed shell commands.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "denied_commands": {
      "type": "array",
      "description": "Explicitly forbidden commands.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "protected_files": {
      "type": "array",
      "description": "Files or globs requiring override to modify.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "network": {
      "type": "object",
      "description": "Network access rules.",
      "properties": {
        "allow": {
          "type": "boolean",
          "default": false
        },
        "allowed_hosts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "limits": {
      "type": "object",
      "required": [
        "max_files_per_patch",
        "max_patch_size",
        "max_context_kb",
        "max_jobs_per_hour"
      ],
      "properties": {
        "max_files_per_patch": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "max_patch_size": {
          "type": "integer",
          "minimum": 1024,
          "description": "Maximum diff size in bytes."
        },
        "max_context_kb": {
          "type": "integer",
          "minimum": 64,
          "description": "Maximum context size in kilobytes."
        },
        "max_jobs_per_hour": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "overrides": {
      "type": "array",
      "description": "Manual override rules.",
      "items": {
        "type": "object",
        "required": ["reason", "expires_at"],
        "properties": {
          "reason": {
            "type": "string",
            "minLength": 5
          },
          "expires_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "description": "Optional policy metadata.",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
