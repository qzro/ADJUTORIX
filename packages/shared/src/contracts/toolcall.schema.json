{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Adjutorix Tool Call Schema",
  "type": "object",
  "required": [
    "tool",
    "arguments",
    "timeout"
  ],
  "properties": {
    "tool": {
      "type": "string",
      "minLength": 1,
      "description": "Registered tool name to be executed."
    },
    "arguments": {
      "type": "object",
      "description": "Arguments passed to the tool implementation.",
      "additionalProperties": true
    },
    "timeout": {
      "type": "integer",
      "minimum": 1000,
      "maximum": 600000,
      "description": "Execution timeout in milliseconds."
    },
    "working_directory": {
      "type": "string",
      "description": "Optional working directory for tool execution."
    },
    "capture_output": {
      "type": "boolean",
      "default": true
    },
    "allow_network": {
      "type": "boolean",
      "default": false
    },
    "retries": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3,
      "default": 0
    },
    "on_failure": {
      "type": "string",
      "enum": ["abort", "retry", "continue"],
      "default": "abort"
    }
  },
  "additionalProperties": false
}
