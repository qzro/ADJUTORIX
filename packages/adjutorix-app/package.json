{
  "name": "@adjutorix/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Adjutorix Desktop Application \u2014 Deterministic Patch-Oriented Workspace",
  "license": "MIT",
  "author": "Adjutorix",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm run build && pnpm exec electron .",
    "build": "pnpm run clean && pnpm run build:ts && pnpm run build:preload-entry && pnpm run build:renderer && pnpm run build:assets",
    "build:ts": "tsc -p tsconfig.json --incremental false --noEmitOnError true",
    "build:renderer": "node ./scripts/build-renderer.mjs",
    "build:assets": "node ./scripts/prepare-renderer-assets.js && node ./scripts/normalize-asset-manifest.cjs",
    "clean": "rimraf dist node_modules/.cache/tsbuildinfo .adjutorix.renderer.entry.html .adjutorix.vite.renderer.config.mjs",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json,css,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "verify": "pnpm run build && pnpm run typecheck && pnpm run lint && pnpm run test",
    "start": "pnpm exec electron .",
    "package": "electron-builder",
    "postinstall": "node ./scripts/postinstall.mjs",
    "build:preload-entry": "node -e \"const fs=require('node:fs');fs.mkdirSync('dist/preload',{recursive:true});fs.copyFileSync('dist/preload/preload.js','dist/preload/preload.mjs')\""
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "date-fns": "^3.6.0",
    "electron": "^30.0.0",
    "framer-motion": "^12.38.0",
    "lodash": "^4.17.21",
    "lucide-react": "^1.7.0",
    "monaco-editor": "^0.55.1",
    "node-fetch": "^3.3.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "superjson": "^2.2.1",
    "uuid": "^9.0.1",
    "ws": "^8.17.0",
    "zod": "^3.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "5.0.0",
    "autoprefixer": "10.4.20",
    "concurrently": "^8.2.2",
    "electron-builder": "^24.13.3",
    "eslint": "^9.9.0",
    "jsdom": "^29.0.2",
    "postcss": "8.4.49",
    "prettier": "^3.3.3",
    "react-router-dom": "^6.30.3",
    "rimraf": "^5.0.7",
    "tailwindcss": "3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "main": "dist/main/index.js",
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "build": {
    "appId": "com.adjutorix.app",
    "productName": "Adjutorix",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
