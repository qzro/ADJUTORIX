{
  "name": "adjutorix",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.6.3",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=10.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "bash ./scripts/check.sh",
    "clean": "bash ./scripts/clean.sh",
    "constitution": "node scripts/adjutorix-constitution-check.mjs",
    "dev": "bash ./scripts/dev.sh",
    "doctor": "bash ./scripts/doctor.sh",
    "lint": "turbo run lint",
    "package:macos": "bash ./scripts/package-macos.sh",
    "smoke": "bash ./scripts/smoke.sh",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "verify": "bash ./scripts/verify.sh",
    "power:verify": "bash scripts/power/verify-adjutorix-power-packages.sh",
    "power:update": "bash scripts/power/update-adjutorix-power-packages.sh"
  },
  "devDependencies": {
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
